# Frontend environment variables
# Copy this file to .env and replace with actual values.

# Google API client ID (optional if using @react-oauth/google login)
VITE_GOOGLE_CLIENT_ID=

# Backend base URL (if needed for API calls)
VITE_BACKEND_URL=http://localhost:5001

# Team directory data Google Apps Script endpoint
# This URL returns JSON rows from Google Sheets
VITE_TEAM_API=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
