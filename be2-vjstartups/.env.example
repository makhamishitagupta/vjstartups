# Backend Environment Variables (be2-vjstartups)
# Copy this file to .env and fill your credentials/secrets.

# MongoDB connection URI (required)
# Example for local MongoDB:
# MONGO_URI=mongodb://localhost:27017/vjstartups
# Example for MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xyz.mongodb.net/vjstartups?retryWrites=true&w=majority
MONGO_URI=

# Server port (default 5001 if empty)
PORT=5001

# Google OAuth client ID (required for /auth/google endpoint)
# You can leave this empty during local development if you bypass auth logic
GOOGLE_CLIENT_ID=

# Cloudinary credentials for image file uploads (required by problem API)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT secret / session token secret (if you add JWT auth later)
JWT_SECRET=your_jwt_secret

# Optional app values
# CLIENT_ID may be used by frontend if required
CLIENT_ID=
